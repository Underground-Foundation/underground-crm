DJANGO_SETTINGS_MODULE=your_theme.settings
DJANGO_PROJECT_DIR=/path/to/your/theme-project
REDIS_URL=redis://127.0.0.1:6379

# Discover the site ID at eg https://…/admin/sites/<site_id>
LEGACY_SITE_ID=1
LEGACY_ADMIN_URL=https://yourlegacycrm.example.com
LEGACY_API_URL=https://yourlegacycrm.example.com/api
LEGACY_API_TOKEN=your-api-bearer-token
LEGACY_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
LEGACY_ADMIN_COOKIE_FILE=/path/to/your/cookies.txt
LEGACY_VIEWER_COOKIE_FILE=/path/to/your/cookies.txt

# The public base URL of the site, with no trailing slash.
# Used in outgoing emails for unsubscription links, membership links, and similar.
# Must be set correctly in production — the default of http://localhost:8000 will
# produce broken links in any email sent from a live environment.
WAGTAILADMIN_BASE_URL=https://yoursite.example.com

# https://app-au.smtp2go.com/sending/apikeys/
SMTP_KEY=your-smtp2go-key
# A separate signing key for unsubscription tokens, allowing it to be rotated
# independently of DJANGO_SECRET_KEY without invalidating sessions or CSRF tokens.
# Falls back to DJANGO_SECRET_KEY if not set.
UNSUBSCRIBE_SIGNING_KEY=your-unsubscribe-signing-key

# Stripe payment processing — https://dashboard.stripe.com/apikeys
# Register the webhook at https://dashboard.stripe.com/webhooks pointing to
# https://yoursite.example.com/payments/webhook/
# Required events: payment_intent.succeeded, invoice.paid
STRIPE_PUBLISHABLE_KEY=pk_test_…
STRIPE_SECRET_KEY=sk_test_…
STRIPE_WEBHOOK_SECRET=whsec_…

# Social login via django-allauth — register OAuth apps at each provider's
# developer console and set the redirect URI to:
#   https://yoursite.example.com/account/<provider>/login/callback/
# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Facebook — https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# Instagram — https://developers.facebook.com/apps/ (requires business verification)
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
# LinkedIn — https://www.linkedin.com/developers/apps
# Redirect URI: https://yoursite.example.com/account/linkedin/login/callback/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
